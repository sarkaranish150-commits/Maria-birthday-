        }

        // PAGE 1: CARD Logic
        function toggleCard() {
            const card = document.getElementById('birthday-card');
            card.classList.toggle('is-open');

            if (card.classList.contains('is-open')) {
                // Burst custom local pink & purple celebration confetti from center
