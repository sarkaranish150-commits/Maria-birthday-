                showToast('💌 Sweet Postbox', 'Enjoy these interactive letters from across the screen!', '💖');
            } else if (pageName === 'cake') {
                showToast('🎂 Cake Design Mode', 'Bake and decorate a gorgeous birthday cake!', '🧁');
                refreshCakeLayout();
