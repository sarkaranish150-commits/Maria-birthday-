        function refreshBlowButtonState() {
            const hasCandlesLit = activeCandles.some(c => c === true);
            const blowBtn = document.getElementById('blow-btn');
            const actionHint = document.getElementById('action-hint');

            if (hasCandlesLit) {
                blowBtn.disabled = false;
                blowBtn.classList.remove('bg-gray-200', 'text-gray-500', 'cursor-not-allowed');
                blowBtn.classList.add('bg-pastelPink-500', 'text-white', 'hover:bg-pastelPink-600', 'animate-bounce');
                actionHint.innerText = "⭐ Yay! Tell Maria to close her eyes, make a wish, and blow!";
            } else {
                blowBtn.disabled = true;
                blowBtn.classList.remove('bg-pastelPink-500', 'text-white', 'hover:bg-pastelPink-600', 'animate-bounce');
                blowBtn.classList.add('bg-gray-200', 'text-gray-500', 'cursor-not-allowed');
                actionHint.innerText = "🕯️ Light up the candles in the Left Panel first!";
            }
        }

        // Spawn glitter sprinkles randomly on the cake layer area
        // Limits positions so they fall nicely on the top or bottom cake tier boundaries
        function spawnGlitter(type) {
            const board = document.getElementById('sprinkle-board');
            const isTopTier = Math.random() > 0.4;
            let leftX, topY;

            const el = document.createElement('div');
            el.className = 'absolute z-30 pointer-events-auto cursor-pointer select-none text-base transition-transform hover:scale-125';

            if (isTopTier) {
                leftX = Math.random() * 140 + 130; 
                topY = Math.random() * 50 + 110; 
            } else {
                leftX = Math.random() * 210 + 100;
                topY = Math.random() * 60 + 190;
            }

            el.style.left = `${leftX}px`;
            el.style.top = `${topY}px`;

            if (type === 'star') {
                el.innerText = '⭐️';
            } else if (type === 'heart') {
                el.innerText = '💖';
            } else if (type === 'dot') {
                el.innerText = '✨';
            } else {
                el.innerText = '🍓';
            }

            el.onclick = function() {
                el.remove();
                if (audioCtx) playTone(293.66, 80);
            };

            board.appendChild(el);
            if (audioCtx) playTone(440.00, 100);
        }

        function clearDecorations() {
            document.getElementById('sprinkle-board').innerHTML = '';
            showToast("🗑️ Cleaned Cake", "Cleared all sprinkles, ready for new styles!", "🧹");
        }

        function blowCandles() {
            // Extinguish flames
            for (let i = 0; i < 3; i++) {
                const flame = document.getElementById(`flame-${i}`);
                if (flame) {
                    flame.classList.add('hidden');
                }
            }

            // Launch beautiful customized side confetti cannons inwards!
            // Left cannon shooting up-right
            triggerConfetti(0, window.innerHeight * 0.8, 60, [-60, -20]);
            // Right cannon shooting up-left
            triggerConfetti(window.innerWidth, window.innerHeight * 0.8, 60, [-160, -120]);
            
            // Center secondary celebration spray
            setTimeout(() => {
                triggerConfetti(window.innerWidth / 2, window.innerHeight * 0.6, 80);
            }, 300);

            setTimeout(() => {
                const modal = document.getElementById('wish-modal');
                modal.classList.remove('translate-y-full', 'opacity-0');
                modal.classList.add('translate-y-0', 'opacity-100');
                
                if (audioCtx) {
                    setTimeout(() => playTone(523.25, 150), 0);
                    setTimeout(() => playTone(659.25, 150), 150);
                    setTimeout(() => playTone(783.99, 300), 300);
                    setTimeout(() => playTone(1046.50, 600), 600);
                }
            }, 800);
        }

        function closeWishModal() {
            const modal = document.getElementById('wish-modal');
            modal.classList.remove('translate-y-0', 'opacity-100');
            modal.classList.add('translate-y-full', 'opacity-0');

            activeCandles = [false, false, false];
            for (let i = 0; i < 3; i++) {
                const btn = document.getElementById(`candle-btn-${i}`);
                const candleObj = document.getElementById(`candle-obj-${i}`);
                const flame = document.getElementById(`flame-${i}`);
                
                btn.classList.remove('bg-pastelPink-500', 'text-white');
                btn.classList.add('bg-pastelPink-50', 'text-pastelPink-500');
                candleObj.classList.add('hidden');
                if (flame) flame.classList.remove('hidden');
            }
            refreshBlowButtonState();
        }

        function refreshCakeLayout() {
            const board = document.getElementById('sprinkle-board');
            if (board.children.length === 0) {
                setTimeout(() => spawnGlitter('star'), 100);
                setTimeout(() => spawnGlitter('heart'), 200);
                setTimeout(() => spawnGlitter('berry'), 300);
                setTimeout(() => spawnGlitter('dot'), 400);
                setTimeout(() => spawnGlitter('star'), 500);
                setTimeout(() => spawnGlitter('heart'), 600);
            }
        }

        window.onload = function() {
            // Smooth entrance confetti sequence
            setTimeout(() => {
                triggerConfetti(window.innerWidth / 2, window.innerHeight * 0.3, 100);
            }, 500);
            
            showToast("💖 Happy Birthday Maria!", "Welcome to your virtual birthday spot!", "🌸");
        };
    </script>
</body>
</html>

