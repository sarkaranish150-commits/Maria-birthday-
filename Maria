                complimentBox.innerText = `"${compliments[randomIdx]}"`;
                complimentBox.style.opacity = 1;
                
                // Blast customized micro-heart confetti bursts
                triggerConfetti(window.innerWidth / 2, window.innerHeight * 0.7, 30);

                // Play magical chime tone
                if (audioCtx) {
                    playTone(659.25, 100);
                    setTimeout(() => playTone(783.99, 100), 100);
                    setTimeout(() => playTone(1046.50, 200), 200);
                }
            }, 250);
        }

        // PAGE 3: INTERACTIVE CAKE BUILDER Logic
        let activeCandles = [false, false, false];
        let cakeColor = "#FFA4B4";

        function setCakeColor(color) {
            cakeColor = color;
            document.getElementById('cake-tier-top').style.backgroundColor = color;
